<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/coffee_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

            <!-- Barra lateral de estado -->
            <View
                android:id="@+id/viewEstadoBar"
                android:layout_width="4dp"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

            <!-- ROW 1: Avatar + Nombre + Badge -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp">

                <!-- Avatar circle -->
                <ImageView
                    android:id="@+id/ivAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_person"
                    android:background="@drawable/info_row_background"
                    android:padding="6dp"
                    android:importantForAccessibility="no"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvCliente"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/lora"
                    android:textColor="@color/coffee_on_surface"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    app:layout_constraintStart_toEndOf="@id/ivAvatar"
                    app:layout_constraintEnd_toStartOf="@id/tvEstado"
                    app:layout_constraintTop_toTopOf="@id/ivAvatar"
                    tools:text="Genesis Blanchard" />

                <TextView
                    android:id="@+id/tvFolio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textColor="@color/text_color_secondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/lato"
                    app:layout_constraintStart_toEndOf="@id/ivAvatar"
                    app:layout_constraintEnd_toStartOf="@id/tvEstado"
                    app:layout_constraintTop_toBottomOf="@id/tvCliente"
                    tools:text="RSV-MRJQLA" />

                <!-- Badge estado -->
                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_estado"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:letterSpacing="0.04"
                    android:fontFamily="@font/lato"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="PENDIENTE" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Fine divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0ECE6"
                android:layout_marginBottom="10dp" />

            <!-- ROW 2: Date + Time (with Material icons) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_calendar"
                    android:layout_marginEnd="4dp"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvFecha"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_on_surface"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato"
                    tools:text="20 Mar 2026" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_clock"
                    android:layout_marginEnd="4dp"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvHora"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_on_surface"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato"
                    tools:text="09:09 - 10:39" />
            </LinearLayout>

            <!-- ROW 3: People + Zone -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_people"
                    android:layout_marginEnd="4dp"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvPersonas"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_on_surface"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato"
                    tools:text="2 personas" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:src="@drawable/ic_location"
                    android:layout_marginEnd="4dp"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvZona"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_on_surface"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato"
                    tools:text="Terraza" />
            </LinearLayout>

            <!-- Promotion badge (hidden by default) -->
            <TextView
                android:id="@+id/txtPromocion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/badge_promocion"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.04"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
