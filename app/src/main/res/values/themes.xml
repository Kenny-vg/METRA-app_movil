<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.ProyectoIntegradorII" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/coffee_primary</item>
        <item name="colorPrimaryVariant">@color/coffee_primary_variant</item>
        <item name="colorOnPrimary">@color/coffee_on_primary</item>
        <item name="colorSecondary">@color/coffee_secondary</item>
        <item name="colorSecondaryVariant">@color/coffee_secondary</item>
        <item name="colorOnSecondary">@color/coffee_on_secondary</item>
        <item name="android:colorBackground">@color/coffee_cream_background</item>
        <item name="colorSurface">@color/coffee_surface</item>
        <item name="colorOnSurface">@color/coffee_on_surface</item>
        <item name="android:statusBarColor">@color/coffee_primary_variant</item>
        <item name="android:windowBackground">@color/coffee_cream_background</item>
        <item name="android:fontFamily">@font/lato</item>
        <item name="fontFamily">@font/lato</item>
        <item name="materialButtonStyle">@style/Widget.App.Button</item>
        <item name="editTextStyle">@style/Widget.App.EditText</item>
        <item name="spinnerStyle">@style/Widget.App.Spinner</item>
        <item name="textAppearanceHeadline1">@style/TextAppearance.App.Headline1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.App.Headline2</item>
        <item name="textAppearanceBody1">@style/TextAppearance.App.Body1</item>
        <item name="textAppearanceSubtitle1">@style/TextAppearance.App.Label</item>
    </style>

    <style name="Theme.ProyectoIntegradorII" parent="Base.Theme.ProyectoIntegradorII" />

    <!-- TEMA DE INICIO (SPLASH DE SISTEMA) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Fondo crema que pediste -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <!-- ESTO PONE EL ICONO DE LA APP ANTES DE TU SPLASH -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <!-- Tema al que cambia cuando entra la Activity -->
        <item name="postSplashScreenTheme">@style/Theme.ProyectoIntegradorII</item>
    </style>

    <!-- Estilos de Texto -->
    <style name="TextAppearance.App.Headline1" parent="TextAppearance.MaterialComponents.Headline1">
        <item name="fontFamily">@font/lora</item>
        <item name="android:fontFamily">@font/lora</item>
        <item name="android:textColor">@color/text_color_primary</item>
        <item name="android:textSize">@dimen/font_size_headline1</item>
    </style>

    <style name="TextAppearance.App.Headline2" parent="TextAppearance.MaterialComponents.Headline2">
        <item name="fontFamily">@font/lora</item>
        <item name="android:fontFamily">@font/lora</item>
        <item name="android:textColor">@color/text_color_primary</item>
        <item name="android:textSize">@dimen/font_size_headline2</item>
    </style>

    <style name="TextAppearance.App.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="fontFamily">@font/lato</item>
        <item name="android:fontFamily">@font/lato</item>
        <item name="android:textColor">@color/text_color_secondary</item>
        <item name="android:textSize">@dimen/font_size_body</item>
    </style>

    <style name="TextAppearance.App.Label" parent="TextAppearance.AppCompat.Subhead">
        <item name="android:fontFamily">@font/lato</item>
        <item name="android:textColor">@color/text_color_primary</item>
        <item name="android:textSize">@dimen/font_size_label</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Estilos de Componentes -->
    <style name="Widget.App.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">@font/lato</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">@dimen/spacing_large</item>
        <item name="android:paddingRight">@dimen/spacing_large</item>
        <item name="android:paddingTop">@dimen/spacing_medium</item>
        <item name="android:paddingBottom">@dimen/spacing_medium</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
    </style>

    <style name="Widget.App.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/edit_text_background</item>
        <item name="android:fontFamily">@font/lato</item>
        <item name="android:textColor">@color/text_color_primary</item>
        <item name="android:textColorHint">@color/text_color_secondary</item>
        <item name="android:padding">@dimen/spacing_medium</item>
    </style>

    <style name="Widget.App.Spinner" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/edit_text_background</item>
        <item name="android:padding">@dimen/spacing_medium</item>
        <item name="android:fontFamily">@font/lato</item>
        <item name="android:textColor">@color/text_color_primary</item>
    </style>

    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:drawable">@drawable/bottom_nav_indicator_style</item>
    </style>
</resources>
