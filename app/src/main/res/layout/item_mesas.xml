<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginTop="5dp"
    android:layout_marginBottom="5dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/coffee_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

            <!-- ═══ BARRA LATERAL DE COLOR ═══ -->
            <View
                android:id="@+id/viewEstadoBar"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/status_available" />

            <!-- ═══ CONTENIDO ═══ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp">

            <!-- Ícono de mesa (vectores, sin emojis) -->
            <ImageView
                android:id="@+id/ivMesaIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_location"
                android:background="@drawable/info_row_background"
                app:tint="@color/coffee_primary"
                android:padding="10dp"
                android:importantForAccessibility="no"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvMesaNombre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/lora"
                android:textColor="@color/coffee_on_surface"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/ivMesaIcon"
                app:layout_constraintEnd_toStartOf="@id/tvMesaEstado"
                app:layout_constraintTop_toTopOf="@id/ivMesaIcon"
                tools:text="Mesa 5" />

            <TextView
                android:id="@+id/tvMesaZona"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:textColor="@color/text_color_secondary"
                android:textSize="12sp"
                android:fontFamily="@font/lato"
                app:layout_constraintStart_toEndOf="@id/ivMesaIcon"
                app:layout_constraintEnd_toStartOf="@id/tvMesaEstado"
                app:layout_constraintTop_toBottomOf="@id/tvMesaNombre"
                tools:text="Terraza" />

            <!-- Badge de estado a la derecha -->
            <TextView
                android:id="@+id/tvMesaEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_estado"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.04"
                android:fontFamily="@font/lato"
                android:textColor="@color/white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="DISPONIBLE"
                tools:backgroundTint="@color/status_available" />

            <!-- Divider -->
            <View
                android:id="@+id/dividerMesa"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0ECE6"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/ivMesaIcon" />

            <!-- Capacidad -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/dividerMesa">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_people"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="4dp"
                    android:importantForAccessibility="no" />

                <TextView
                    android:id="@+id/tvMesaCapacidad"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_on_surface"
                    android:textSize="13sp"
                    android:fontFamily="@font/lato"
                    tools:text="Capacidad 8 personas" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
